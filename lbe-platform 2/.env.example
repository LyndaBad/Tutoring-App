# ─────────────────────────────────────────────────────────────────
#  Lynda Badmus Education — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────

# ── SUPABASE (required for real auth + database) ──────────────────
# Find these in: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── ANTHROPIC (optional — for the AI Course Guide chat widget) ────
# Get your key at: https://console.anthropic.com
# The app works without this — AI widget will show a connection error
VITE_ANTHROPIC_API_KEY=sk-ant-your-key-here
