# Copy this file to .env for local development.
# In production (Vercel), set these under Project → Settings → Environment Variables.

# Supabase — real accounts & data (optional: demo logins work without it)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Anthropic — powers the AI Course Guide chat widget (optional)
# Locally this is used by the Vite dev proxy. On Vercel, set ANTHROPIC_API_KEY (no VITE_ prefix).
VITE_ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here
