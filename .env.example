# Copy this file to `.env` and fill in the values.
# `.env` is gitignored — never commit it.

# ─── Supabase ──────────────────────────────────────────────────────────
# Get these from your Supabase project dashboard → Project Settings → API.
# The anon key is safe to ship to the browser; do NOT put the service_role key here.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ─── Anthropic (AI Course Guide chat widget) ───────────────────────────
# Only needed if you want the chat widget to work. Get one at console.anthropic.com.
# In production this should live on your server (Vercel serverless fn), not here.
VITE_ANTHROPIC_API_KEY=sk-ant-your-key-here
